From 403691832aed2cb32974163688efb295967f7c83 Mon Sep 17 00:00:00 2001
From: Nima Aghayan <n.aghayan@crouse.ir>
Date: Sat, 18 Jul 2026 14:59:49 +0000
Subject: [PATCH] arm: dts: licheepi-zero: add GD25B512ME SPI NOR

---
 arch/arm/boot/dts/sun8i-v3s-licheepi-zero.dts | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/arch/arm/boot/dts/sun8i-v3s-licheepi-zero.dts b/arch/arm/boot/dts/sun8i-v3s-licheepi-zero.dts
index f9d4dc4ec..b3f1b45ae 100644
--- a/arch/arm/boot/dts/sun8i-v3s-licheepi-zero.dts
+++ b/arch/arm/boot/dts/sun8i-v3s-licheepi-zero.dts
@@ -116,3 +116,13 @@ &usbphy {
 	usb0_id_det-gpios = <&pio 5 6 GPIO_ACTIVE_HIGH>;
 	status = "okay";
 };
+
+&spi0 {
+    status = "okay";
+
+    flash@0 {
+        compatible = "gigadevice,gd25b512me", "jedec,spi-nor";
+        reg = <0>;
+        spi-max-frequency = <50000000>;
+    };
+};
\ No newline at end of file
-- 
2.34.1

